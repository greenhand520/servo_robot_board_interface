# Board Power Data
# Servo power electrical measurements

uint16  servo_voltage_mv      # Servo rail voltage (mV)
uint16  servo_current_ma      # Servo rail current (mA)
uint16  charge_in_voltage_mv  # USB-PD input voltage (mV)
uint16  charge_in_current_ma  # USB-PD input current (mA)
uint16  bat_voltage_mv        # Battery voltage (mV)
int16   bat_current_ma        # Battery current (mA)
